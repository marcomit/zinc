foreign *u8 malloc(u64)
foreign *u8 realloc(*u8, u64)
foreign u0 free(*u8)

pub struct Allocator {
    u64 bytes
}

pub *u8 alloc(u64 size) Allocator self {
    return malloc(size)
}

pub *u8 realloc(*u8 ptr, u64 size) Allocator self {
    return realloc(ptr, size)
}

pub u0 free(*u8 ptr) Allocator self {
    free(ptr)
}
