"prova"
// Test file for Zinc tokenizer
// Tests all token categories and edge cases

// Flow control keywords
if (x == 10) {
    return 42
} else {
    while (y) {
        continue
    }
}

do {
    goto label
} while (0)


// Type keywords
void foo(void)
char c
int num
float f
double d
short s
long l

struct Point {
    int x
    int y
}

union Data {
    int i
    float f
}

typedef struct Node Node

enum Color {
    RED,
    GREEN,
    BLUE
}

// Symbols and operators - edge cases
int *ptr
int **pptr
struct Point *p
p->x = 5
p->y = 10

// Test arrow vs minus
x->y
x - y
x--
x-=5

// Test equality vs assignment
if (a == b) {}
a = b

// All brackets
int arr[10]
struct S { int x }
func(a, b, c)

// Operators
x = a + b
y = c - d
z = e * f
w = g / h
ptr = &x
val = *ptr

// Adjacency tests (no spaces)
x=y+z*w/v
arr[0]=10
p->x=p->y
if(x==y){}
while(a){}

// Multi-character symbol tests
->->->
====
--
++
***

// Literals and identifiers
"hello world"
"escape \"quotes\""
42
0
-1
true
false
identifier123
_underscore
CamelCase

// Comma-separated lists
func(a, b, c, d)
int x, y, z
struct { int a, b, c }

// Dot operator
s.field
p->s.field

// Complex expressions
result = (a + b) * (c - d) / e
array[index] = *ptr->field
(*callback)(arg1, arg2, arg3)

// Potential ambiguities
// Arrow vs minus + greater
a->b
a - >b  // This is "a - (>b)" which should error on >

// Deref vs multiply
int *p = &x
z = a * b
z = *p

// Edge case: symbols at boundaries
{{{}}}
((()))
[[[]]]

// All symbols in sequence
( ) { } [ ] & * + - / , = . ->

// End of file - no newline
