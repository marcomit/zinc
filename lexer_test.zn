// Point struct with embedded anonymous struct
struct Point {
    int x
    int y
}

// Shape struct with embedded Point
struct Shape {
    Point
    int color
    struct {
        int visible
        int layer
    }
}

// Rectangle struct with named Point
struct Rectangle {
    Point topleft
    Point bottomright
}

// Regular function
int add(int a, int b) {
    return a + b
}

// Function with pointer arithmetic
int sum_array(int[] arr, int size) {
    int total = 0
    for int i = 0, i < size, i = i + 1 {
        total = total + arr[i]
    }
    return total
}

// Receiver function for Point
void print() Point p {
    printf("Point(%d, %d)", p.x, p.y)
}

// Receiver function for Point with calculation
int distance_squared() Point p {
    return p.x * p.x + p.y * p.y
}

// Receiver function for Shape (uses embedded fields)
void display() Shape s {
    printf("Shape at (%d, %d) color=%d", s.x, s.y, s.color)
    if s.visible and s.layer > 0 {
        printf(" [visible on layer %d]", s.layer)
    }
}

// Function demonstrating pointer dereferencing
void move(*Point p, int dx, int dy) {
    p.x = p.x + dx  // auto-dereference
    p.y = p.y + dy
}

// Main function
int main() {
    // Create points
    Point p1 = {10, 20}
    Point p2 = {30, 40}
    
    // Test regular function
    int sum = add(p1.x, p2.y)
    
    // Test receiver function
    p1.print()
    
    // Create shape with embedded Point
    Shape shape = {5, 10, 255, 1, 2}
    shape.display()
    
    // Access embedded fields directly
    shape.x = 100
    shape.y = 200
    
    // Create rectangle with named Point fields
    Rectangle rect = {{0, 0}, {100, 100}}
    rect.topleft.print()
    rect.bottomright.print()
    
    // Test pointer operations
    *Point ptr = &p1
    move(ptr, 5, 5)
    ptr.print()  // auto-dereference
    
    // Test logical operators
    if p1.x > 0 and p1.y > 0 {
        printf("Point in first quadrant")
    }
    
    if not (p1.x == 0 or p1.y == 0) {
        printf("Point not on axis")
    }
    
    // Array example
    int[] numbers = {1, 2, 3, 4, 5}
    int total = sum_array(numbers, 5)
    
    // Pointer arithmetic with array
    int[] ptr_num = numbers
    ptr_num = ptr_num + 2  // points to third element
    printf("Third element: %d", *ptr_num)
    
    return 0
}
