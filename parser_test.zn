module "std"

struct Point {
	int x
	int y
	float distance
}

const int globalVar

int pow(int a) int self {
	while self > 0 {
		a = a * a
		self = self - 1
	}
	return a
}

int main(int argc, **char argv) {
	int a = 2
	a.pow(10)
	return 0
}



float distance(*Point b) *Point a {
	return (a + 1).x()
}
