foreign u0 printf(*char)

u32 main() {
    arr := ["a", "b", "c", "d"]
    arr[0] = "first"
    arr[3] = "last"

    printf(arr[0])
    printf(arr[3])
    
    printf("\n")

    i := 1
    arr[i] = "expr"
    printf(arr[i])

    printf("\n")

    arr[i + 1] = "arith"
    printf(arr[i + 1])

    printf("\n")

    arr[0] = arr[2]
    printf(arr[0])


    return 0
}
