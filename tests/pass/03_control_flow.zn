foreign u0 printf(*char)

i32 main(i32 argc) {

    i32 x = 5
    if x == 5  { printf("eq\n")  }
    if x != 4  { printf("neq\n") }
    if x > 4   { printf("gt\n")  }
    if x < 6   { printf("lt\n")  }
    if x >= 5  { printf("gte\n") }
    if x <= 5  { printf("lte\n") }
    if x == 6  { printf("NOPE\n") }

    if argc == 1 { printf("one arg\n") }

    i := 0
    for i < 3 {
        printf("while\n")
        i = i + 1
    }

    for j := 0; j < 3; j = j + 1 {
        printf("for\n")
    }

    for i32 j = 0; j < 3; j = j + 1 {
        printf("for typed\n")
    }

    k := 0
    for k < 10 {
        k = k + 1
        if k > 3 { break }
    }
    printf("break\n")

    m := 0
    for m < 5 {
        m = m + 1
        if m < 3 { continue }
        printf("cont\n")
    }

    defer printf("f0\n")
    defer printf("f1\n")

    if true {
        defer printf("if\n")
    }

    n := 2
    for n > 0 {
        defer printf("loop\n")
        n = n - 1
    }

    defer printf("f2\n")

    return 0
}
