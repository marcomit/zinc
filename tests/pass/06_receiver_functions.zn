foreign u0 printf(*char)
foreign i32 putchar(i32)


struct Counter {
    i32 count
}

struct Rect {
    i32 w
    i32 h
}

for Counter self {
    u0 print() {
        putchar(48 + self.count)
        putchar(10)
    }

    i32 get() {
        return self.count
    }

    i32 add(i32 n) {
        return self.count + n
    }

    i32 between(i32 lo, i32 hi) {
        if self.count <= lo { return 0 }
        if self.count >= hi { return 0 }
        return 1
    }
}

for Rect self {
    i32 area() {
        return self.w * self.h
    }

    u0 describe() {
        putchar(48 + self.w)
        putchar(32)
        putchar(48 + self.h)
        putchar(10)   
    }

    i32 scaledArea(i32 factor) {
        return self.w * self.h * factor
    }
}

for i32 self {
    i32 sum(i32 other) {
        return other + self
    }
}

// Auto-dereference not yet implemented
// u0 inc(*Counter self) {
//     self.count = self.count + 1
// }

i32 main() {
    Counter c = Counter { count: 3 }

    c.print()

    i32 v = c.get()
    putchar(48 + v)
    putchar(10)

    i32 sum = c.add(4)
    putchar(48 + sum)
    putchar(10)

    i32 inside = c.between(1, 5)
    putchar(48 + inside)
    putchar(10)

    i32 outside = c.between(4, 9)
    putchar(48 + outside)
    putchar(10)

    Rect r = Rect { w: 3, h: 4 }

    r.describe()

    i32 area = r.area()
    putchar(48 + area)
    putchar(10)

    i32 scaled = r.scaledArea(2)
    putchar(48 + scaled)
    putchar(10)

    Counter a = Counter { count: 1 }
    Counter b = Counter { count: 2 }
    putchar(48 + a.get())
    putchar(10)
    putchar(48 + b.get())
    putchar(10)

    return 0
}
