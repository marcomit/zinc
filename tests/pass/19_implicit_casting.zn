foreign u0 putchar(char)
foreign *u8 malloc(u64)


f32 sum(f64 x, f64 y) {
    return x + y
}

struct Vec {
    f32 x
    f32 y
}

i32 main() {
    i32 val = 10
    v := Vec{ x: val, y: 10 }
    i32 res = sum(v.x, v.y)

    putchar(48 + res)
    putchar(10)

    *Vec ptr = malloc(sizeof Vec)

    return res - res
}
