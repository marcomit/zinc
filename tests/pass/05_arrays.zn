foreign u0 printf(*char)
foreign i32 putchar(i32)

i32 main() {
    intArr := [1, 2, 3, 4, 5, 6]

    boolArr := [false, true, false, true]

    arr := ["a", "b", "c", "d"]
    arr[0] = "first"
    arr[3] = "last"
    printf(arr[0])
    printf(arr[3])
    printf("\n")

    i := 1
    arr[i] = "expr"
    printf(arr[i])
    printf("\n")

    arr[i + 1] = "arith"
    printf(arr[i + 1])
    printf("\n")

    arr[0] = arr[2]     // arr[2] == "arith"
    printf(arr[0])
    printf("\n")

    chars := [65, 66, 67, 68] as []char

    buf := [5]i32
    j := 0
    for j < 5 {
        buf[j] = j
        j = j + 1
    }
    j = 0
    for j < 5 {
        putchar(48 + buf[j])
        putchar(10)
        j = j + 1
    }

    return 0
}
