use "vec"

foreign u64  strlen(*char)
foreign i32  strcmp(*char, *char)
foreign i32  strncmp(*char, *char, u64)
foreign i32  printf(*char)
foreign void panic(*char)

// ---------------------------------------------------------------------------
// OptionU64 — used by String.find
// ---------------------------------------------------------------------------

struct Option[T] {
    bool valid
    T value
}

struct OptionU64 {
    bool valid
    u64  value
}

Option[T] Option::some(T val) {
    return Option[T] { valid: true, value: val }
}

Option[T] Option::none() {
    return Option[T] { valid: false, value: none }
}

OptionU64 OptionU64_some(u64 val) {
    return OptionU64 { valid: true, value: val }
}

OptionU64 OptionU64_none() {
    return OptionU64 { valid: false, value: 0 }
}

bool is_some() OptionU64 self {
    return self.valid
}

u64 unwrap() OptionU64 self {
    return self.value
}

// ---------------------------------------------------------------------------
// String
// ---------------------------------------------------------------------------

struct String {
    Vec[char] vec
}

// --- Constructors ---

String String::new(*char s) {
    u64 len = strlen(s)
    v := Vec[char] { data: null, len: 0, cap: 0 }

    u64 i = 0
    for i < len {
        v.push(s[i])
        i = i + 1
    }
    v.push('\0')

    d := v.data
    l := v.len
    c := v.cap
    v.forget()

    return String { vec: Vec[char] { data: d, len: l, cap: c } }
}

String String::from(*char s) {
    return String::new(s)
}

// --- Read-only methods ---

*char c_str() String self {
    return self.vec.data
}

u64 length() String self {
    if self.vec.len == 0 { return 0 }
    return self.vec.len - 1
}

bool is_empty() String self {
    return self.length() == 0
}

bool eq(*String other) String self {
    zero := 0
    return strcmp(self.c_str(), other.c_str()) == zero
}

bool eq_str(*char s) String self {
    zero := 0
    return strcmp(self.c_str(), s) == zero
}

bool starts_with(*char prefix) String self {
    plen := strlen(prefix)
    if plen > self.length() { return false }
    zero := 0
    return strncmp(self.c_str(), prefix, plen) == zero
}

bool ends_with(*char suffix) String self {
    slen := strlen(suffix)
    len  := self.length()
    if slen > len { return false }
    offset := len - slen
    zero   := 0
    return strcmp(self.vec.data + offset, suffix) == zero
}

OptionU64 find(char target) String self {
    len := self.length()
    u64 i = 0
    for i < len {
        if self.vec.data[i] == target {
            return OptionU64_some(i)
        }
        i = i + 1
    }
    return OptionU64_none()
}

bool contains(char target) String self {
    return self.find(target).is_some()
}

String substring(u64 start, u64 len) String self {
    if start + len > self.length() {
        panic("substring out of bounds")
    }
    v := Vec[char] { data: null, len: 0, cap: 0 }
    u64 i = 0
    for i < len {
        v.push(self.vec.data[start + i])
        i = i + 1
    }
    v.push('\0')

    d := v.data
    l := v.len
    c := v.cap
    v.forget()

    return String { vec: Vec[char] { data: d, len: l, cap: c } }
}

String add(*String other) String self {
    new_s := String_new(self.c_str())
    new_s.append(other)

    d := new_s.vec.data
    l := new_s.vec.len
    c := new_s.vec.cap
    new_s.forget()

    return String { vec: Vec[char] { data: d, len: l, cap: c } }
}

void print() String self {
    printf(self.vec.data)
}

void println() String self {
    printf(self.vec.data)
    printf("\n")
}

// --- Mutating methods ---

void destroy() *String self {
    self.vec.free()
}

void free() *String self {
    self.vec.free()
}

void forget() *String self {
    self.vec.forget()
}

void reserve(u64 cap) *String self {
    self.vec.grow_to_fit(cap + 1)
}

void append(*String other) *String self {
    if self.vec.len > 0 {
        self.vec.len = self.vec.len - 1
    }
    u64 i = 0
    other_len := other.vec.len
    for i < other_len {
        self.vec.push(other.vec.data[i])
        i = i + 1
    }
}

void append_c(*char s) *String self {
    if self.vec.len > 0 {
        self.vec.len = self.vec.len - 1
    }
    len := strlen(s)
    u64 i = 0
    for i < len {
        self.vec.push(s[i])
        i = i + 1
    }
    self.vec.push('\0')
}

// append_c_ptr: standalone function for explicit pointer callers
void String_append_c_ptr(*String ptr, *char s) {
    if ptr.vec.len > 0 {
        ptr.vec.len = ptr.vec.len - 1
    }
    len := strlen(s)
    u64 i = 0
    for i < len {
        ptr.vec.push(s[i])
        i = i + 1
    }
    ptr.vec.push('\0')
}

// --- UTF-8 support ---

u64 String_utf8_seq_len(char first_byte) {
    if first_byte < 128  { return 1 }
    if first_byte >= 192 and first_byte < 224 { return 2 }
    if first_byte >= 224 and first_byte < 240 { return 3 }
    if first_byte >= 240 { return 4 }
    return 1
}

u64 utf8_len() String self {
    u64 count = 0
    u64 i = 0
    len := self.length()
    for i < len {
        c := self.vec.data[i]
        i = i + String_utf8_seq_len(c)
        count = count + 1
    }
    return count
}

String utf8_at(u64 idx) String self {
    u64 count = 0
    u64 i = 0
    len := self.length()
    for i < len {
        c   := self.vec.data[i]
        seq := String_utf8_seq_len(c)
        if count == idx {
            return self.substring(i, seq)
        }
        i     = i + seq
        count = count + 1
    }
    return String_new("")
}

String utf8_substr(u64 start_idx, u64 num_chars) String self {
    if num_chars == 0 { return String_new("") }

    u64 byte_start  = 0
    u64 byte_len    = 0
    u64 count       = 0
    u64 i           = 0
    len            := self.length()
    found_start    := false

    for i < len {
        if not found_start and count == start_idx {
            byte_start  = i
            found_start = true
            count       = 0
        }

        if not found_start {
            c     := self.vec.data[i]
            i      = i + String_utf8_seq_len(c)
            count  = count + 1
        } else if count < num_chars {
            c        := self.vec.data[i]
            seq      := String_utf8_seq_len(c)
            byte_len  = byte_len + seq
            i         = i + seq
            count     = count + 1
        } else {
            goto utf8_substr_done
        }
    }
    utf8_substr_done:

    if not found_start { return String_new("") }

    return self.substring(byte_start, byte_len)
}

Vec[String] split(char delim) String self {
    parts := Vec[String] { data: null, len: 0, cap: 0 }
    len   := self.length()
    if len == 0 { return parts }

    u64 start = 0
    u64 i     = 0
    for i < len {
        if self.vec.data[i] == delim {
            parts.push(self.substring(start, i - start))
            start = i + 1
        }
        i = i + 1
    }

    if start <= len {
        parts.push(self.substring(start, len - start))
    }

    return parts
}

String trim() String self {
    u64 start = 0
    len      := self.length()
    u64 end   = len

    for start < len {
        c := self.vec.data[start]
        if c != ' ' and c != '\t' and c != '\n' and c != '\r' {
            goto trim_start_done
        }
        start = start + 1
    }
    trim_start_done:

    if start == len { return String_new("") }

    for end > start {
        c := self.vec.data[end - 1]
        if c != ' ' and c != '\t' and c != '\n' and c != '\r' {
            goto trim_end_done
        }
        end = end - 1
    }
    trim_end_done:

    return self.substring(start, end - start)
}

String replace(*char target, *char replacement) String self {
    t_len := strlen(target)
    if t_len == 0 {
        return self.substring(0, self.length())
    }

    s_len  := self.length()
    result := String_new("")
    u64 i   = 0

    for i < s_len {
        if i + t_len <= s_len {
            is_match := true
            u64 k     = 0
            for k < t_len and is_match {
                if self.vec.data[i + k] != target[k] {
                    is_match = false
                }
                k = k + 1
            }

            if is_match {
                r_str := String_new(replacement)
                result.append(&r_str)
                r_str.free()
                i = i + t_len
                goto replace_next
            }
        }

        // Append single char — strip null, push char, re-terminate
        if result.vec.len > 0 {
            result.vec.len = result.vec.len - 1
        }
        result.vec.push(self.vec.data[i])
        result.vec.push('\0')
        i = i + 1

        replace_next:
    }

    return result
}
