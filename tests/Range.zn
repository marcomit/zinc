use "tests/MathUtil"

struct range {
    i64 start
    i64 end
    i64 current
}

i64 next() *range self {
    self.current = self.current + 1
    return self.current
}

bool hasNext() *range self {
    return self.current < self.end - 1
}

range Range(i64 start, i64 end) {
    return range{ start: start, end: end, current: 0 }
}

