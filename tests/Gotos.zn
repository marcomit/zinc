macro while $cond  $body  {
    entry:
    if !($cond) goto end_while
    $body
    goto entry
    end_while:
}

macro for @item in $list  $body  {
    entry:
    if !($list.hasNext()) goto end_for
    @item := $list.next()
    $body
    goto entry
    end_for:
}

macro for @decl in $start .. $end $block {
    @decl := $start
    while @decl < $end {
        $body
        @decl = @decl + 1
    }
}

void Main() {
    arr := Vec::new[int]()

    for i in 0..10 {
        arr.Push(i)
    }

    for num in arr {
        println("Num: {}".fmt(num)
    }
}
