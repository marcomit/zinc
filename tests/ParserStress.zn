// ============================================================================
// Parser Stress Test for Zinc Language
// This file tests various parsing scenarios and edge cases
// ============================================================================

// ----------------------------------------------------------------------------
// Module Imports
// ----------------------------------------------------------------------------
// use "tests/Data.zn"
// use "tests/Range.zn"

// ----------------------------------------------------------------------------
// Foreign Function Declarations
// ----------------------------------------------------------------------------
foreign void putchar(u8)
foreign void puts(*u8)
foreign i32 printf(*u8)
foreign *void malloc(u64)
foreign void free(*void)
foreign *void realloc(*void, u64)
foreign i32 strcmp(*u8, *u8)
foreign u64 strlen(*u8)

// ----------------------------------------------------------------------------
// Type Aliases (typedef)
// ----------------------------------------------------------------------------
type Byte u8
type Word u16
type DWord u32
type QWord u64
type Size u64
type Pointer *void
type String *u8
type ByteArray [u8]
type IntArray [i32]
type FloatArray [f64]
type PointerArray [*void]
type Matrix [[f64]]
type NestedArray [[[i32]]]

// Generic type aliases
/* type Optional[T] *T
type Ref[T] *T
type ConstRef[T] const *T
