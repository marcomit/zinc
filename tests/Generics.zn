struct Vec[T] {
    *T data
    u64 len
    u64 cap
}

struct Pair[K, V] {
    K key
    V value
}

struct Node[T] {
    T value
    *Node[T] next
}

type Ptr[T] *T

type List[T] [T]

type Result[T, E] Pair[T, E]

void swap[T](*T a, *T b) {
    T tmp = *a
    T valB = *b
}

T max[T](T a, T b) {
    if a > b {
        return a
    }
    return b
}

Pair[K, V] makePair[K, V](K key, V value) {
    Pair[K, V] p
    p.key = key
    p.value = value
    return p
}

void push[T](T item) Vec[T] self {
    if self.len >= self.cap {
        self.grow()
    }
    self.data[self.len] = item
    self.len = self.len + 1
}

*T get[T](u64 index) Vec[T] self {
    if index >= self.len {
        return null
    }
    return &self.data[index]
}

u64 len[T]() Vec[T] self {
    return self.len
}

void grow[T]() Vec[T] self {
    new_cap := self.cap * 2
    if new_cap == 0 {
        new_cap = 8
    }
    self.cap = new_cap
}

type PairList[K, V] Vec[Pair[K, V]]

type NodeArray[T] [Node[T]]

type NodePtr[T] *Node[T]

void main() {
    Vec[i32] numbers
    numbers.len = 0
    numbers.cap = 0

    numbers.push(10)
    numbers.push(20)
    numbers.push(30)

    Pair[i32, f32] pair
    pair.key = 42
    pair.value = 3.14

    i32 a = 5
    i32 b = 10
    swap(&a, &b)

    result := max(a, b)

    Vec[Pair[i32, i32]] pairVec

    [*Node[i32]] nodePointers

    *Vec[f64] floatVecPtr
}
