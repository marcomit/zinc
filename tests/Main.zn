struct Node[T] {
    T data
    *Node[T] next
    *Node[T] prev
}

i32 arraySum(*i32 arr, u64 len) {
    sum := 0
    i   := 0
    for i < len {
        sum = sum + arr[i]
        i   = i + 1
    }
    return sum
}

