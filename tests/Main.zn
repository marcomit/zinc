foreign f32 cos(f32)
foreign f32 sin(f32)
foreign f32 tan(f32)
foreign f32 atan(f32)

pub struct Vec2 {
    f32 x
    f32 y
}

pub Vec2 origin(u8 test) {
    return Vec2 { x: 0, y: 0 }
}

pub f32 angle() *Vec2 v {
    return atan(v.y / v.x)
}

u8 main() {
    u8 x = 1
    // x := 1

    o := origin(test)

    o.angle()

    if o.x {
        return 1
    }
    return 0
}
