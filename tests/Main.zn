use "tests/Data"

pub struct Vec2 {
    f32 x
    f32 y
}

struct PrivateStruct {
    f32 y
}

Vec2 origin(u8 test) {
    return Vec2 { x: 0, y: 0 }
}

f32 angle() Vec2 v {
    return v.y / v.x
}

u8 main() {
    u8 x = 1
    // x := 1

    o := origin(test)

    *u8 ptr = none

    o.angle()

    if o.x {
        return 1
    }
    return 0
}
