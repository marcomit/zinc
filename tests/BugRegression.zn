// ============================================================================
// Bug Regression Test File
//
// Each section is labeled with the bug ID it exercises.
// After a fix, the section should compile cleanly or produce only the
// expected diagnostic listed in the comment — NOT crash or emit spurious
// errors.
//
// Bug reference:
//   P2  - parseUnionDecl expects closing brace before opening brace
//   P3  - parseMatch always returns NULL
//   P4  - parseStructLit: inner 'node' shadows outer 'node' (fields lost)
//   P5  - parseTupleLit: last element before ')' is never pushed
//   M1  - expandMacro: debug printf statements pollute stdout
//   M2  - matchMacroPattern: Z_MACRO_OM / Z_MACRO_ZM not handled
//   S1  - resolveArrSubscript: NULL deref before null-check (crash)
//   S3  - putFunc stores return type, not function type
//         => "Must be a function type" for all statement-level calls
//   S4  - analyzeFor: increment expression never analyzed
//         => type errors / undefined vars in incr silently ignored
//   S5  - analyzeIf: Z_TYPE_COMPARABLE_MASK check always passes
//         => structs/arrays accepted as if-conditions with no error
//   S6  - NODE_STRUCT_LIT: field type is NULL, so field values never type-checked
//   S7  - resolveType NODE_CALL with NODE_MEMBER callee returns NULL
// ============================================================================

foreign i32 printf(*char)

// ------------------------------------------------------------------ base types
struct Point {
    i32 x
    i32 y
}

struct Rect {
    Point topLeft
    Point botRight
}
u0 testTupleLit(i32 a, i32 b) {
    t := (a, b)
}
macro greet $msg {
    printf($msg)
}

u0 testMacroDebugOutput() {
    greet "hello"
}
u0 testArrSubscriptNullDeref(*i32 arr) {
    x := nosuchvar[0]
}
i32 helperAdd(i32 a, i32 b) {
    return a + b
}

u0 testStatementLevelCall() {
    // With bug: "Must be a function type" on the line below
    r := helperAdd(1, 2)
    // printf call is foreign so follows the same path:
    printf("test\n")
}
u0 testForIncrementNotAnalyzed() {
    i32 i = 0
    i32 limit = 10
    // Currently: no error about 'ghostVar' because incr is never analyzed
    // After fix: should error on undefined 'ghostVar'
    for i := 0; i < limit; i = i + 1 {
        i = i + 1
    }
}

u0 testStructAsIfCondition() {
    Point p
    p.x = 1
    p.y = 2
    if p {
        printf("bug: struct accepted as if-condition\n")
    }
}

u0 testStructLitFieldTypeCheck() {
    p := Point { x: 3.14, y: 0 }
}

i32 getX() Point self {
    return self.x
}

u0 testMethodCallReturnsNull() {
    Point p
    p.x = 42
    p.y = 0
    result := p.getX()
}

u0 main() {
    testMatch(1)
    testStructLitFieldShadowing()
    testTupleLit(1, 2)
    testMacroDebugOutput()
    testArrSubscriptNullDeref(none)
    testStatementLevelCall()
    testForIncrementNotAnalyzed()
    testStructAsIfCondition()
    testStructLitFieldTypeCheck()
    testMethodCallReturnsNull()
}
