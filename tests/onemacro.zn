// Option unwrap with guard
macro guard let @var = $opt else $body -> {
    if $opt == None {
        $body
    }
    @var := unwrap($opt)
}

// Match-like guard for Result types
macro guard ok @var = $result else $body -> {
    if is_err($result) {
        $body
    }
    @var := unwrap_ok($result)
}

// Loop with labeled break
macro loop @label $body -> {
    @label: while true {
        $body
    }
}

// Repeat-while (do-while)
macro repeat $body while $cond -> {
    $body
    while $cond {
        $body
    }
}

// For-in style iteration (if you have iterators)
macro for @item in $iter $body -> {
    @it := iterator($iter)
    while has_next(@it) {
        @item := next(@it)
        $body
    }
}

// Range with step
macro for @i from $start to $end step $step $body -> {
    @i := $start
    while @i < $end {
        $body
        @i = @i + $step
    }
}

// Downward range
macro for @i from $start downto $end $body -> {
    @i := $start
    while @i > $end {
        $body
        @i = @i - 1
    }
}

// Ternary operator simulation
macro ifelse $cond then $true_expr else $false_expr -> {
    if $cond { $true_expr } else { $false_expr }
}

// Try-catch style error handling
macro try $body catch @err $handler -> {
    @result := $body
    if is_err(@result) {
        @err := get_error(@result)
        $handler
    }
}

// Assert macro
macro assert $cond -> {
    if !($cond) {
        panic("Assertion failed")
    }
}

// Assert with message
macro assert $cond , $msg -> {
    if !($cond) {
        panic($msg)
    }
}

