macro for @item from $start to $end $body -> {
    @item := $start
    while @item < $end {
        $body
        @item = @item + 1
    }
}

macro unless $cond $body -> {
    if !($cond) {
        $body
    }
}

macro range @i $start to $end $body -> {
    @i := $start
    while $start < $end { $body }
}

void main() {
	guard 0 > 10 print(i) else {
		print('000000')
	}
}

